# Absolute path to cicflowmeter executable installed with uv
# Example: /home/user/cicflowmeter/.venv/bin/cicflowmeter
CICFLOWMETER_PATH=/absolute/path/to/cicflowmeter/.venv/bin/cicflowmeter

# Network interface to listen on
# Example: eth0, ens33
NETWORK_INTERFACE=eth0

# Optional output directory for generated CSV files
# Default: data/raw/captures
CAPTURE_OUTPUT_DIR=data/raw/captures
